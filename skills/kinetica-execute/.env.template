# Kinetica GPU Database Connection Configuration
# Copy this file to .env and fill in your values

# Kinetica server URL (required)
KINETICA_DB_SKILL_URL=http://localhost:9191

# Authentication — use EITHER username/password OR OAuth token
KINETICA_DB_SKILL_USER=
KINETICA_DB_SKILL_PASS=

# Alternative: OAuth token authentication
KINETICA_DB_SKILL_OAUTH_TOKEN=

# Optional: request timeout in milliseconds (default: 30000)
KINETICA_DB_SKILL_TIMEOUT=30000
